+def _load_kb_infos_sync(
+    kb_names: list[str],
+    own_prefix: str,
+    access_by_id: dict[str, dict],
+    is_admin: bool,
+) -> list[KnowledgeBaseInfo]:
+    """Run KB info loading synchronously in a thread pool to avoid blocking
+    the async event loop with disk I/O (kb_config.json, directory scans)."""
+    manager = get_kb_manager()
+    result: list[KnowledgeBaseInfo] = []
+    errors: list[str] = []
+
+    for name in kb_names:
+        try:
+            info = manager.get_info(name)
+            logger.debug(f"Successfully got info for KB '{name}': {info.get('statistics', {})}")
+            result.append(
+                KnowledgeBaseInfo(
+                    id=f"{own_prefix}{info['name']}",
+                    name=info["name"],
+                    is_default=info["is_default"],
+                    statistics=info.get("statistics", {}),
+                    metadata=info.get("metadata"),
+                    path=info.get("path"),
+                    status=info.get("status"),
+                    progress=info.get("progress"),
+                    source="admin" if is_admin else "user",
+                    assigned=False,
+                    read_only=False,
+                    provenance_label=access_by_id.get(f"{own_prefix}{info['name']}", {}).get(
+                        "provenance_label"
+                    ),
+                )
+            )
+        except Exception as e:
+            error_msg = f"Error getting info for KB '{name}': {e}"
+            errors.append(error_msg)
+            logger.warning(f"{error_msg}\n{traceback.format_exc()}")
+            try:
+                kb_dir = manager.base_dir / name
+                if kb_dir.exists():
+                    logger.debug(f"KB '{name}' directory exists, creating fallback info")
+                    result.append(
+                        KnowledgeBaseInfo(
+                            id=f"{own_prefix}{name}",
+                            name=name,
+                            is_default=name == manager.get_default(),
+                            statistics={
+                                "raw_documents": 0,
+                                "images": 0,
+                                "content_lists": 0,
+                                "rag_initialized": False,
+                            },
+                            metadata=None,
+                            path=str(kb_dir),
+                            status="unknown",
+                            progress=None,
+                            source="admin" if is_admin else "user",
+                        )
+                    )
+            except Exception as fallback_err:
+                logger.error(f"Fallback also failed for KB '{name}': {fallback_err}")
+
+    if errors and not result:
+        error_detail = f"Failed to load knowledge bases. Errors: {'; '.join(errors)}"
+        logger.error(error_detail)
+        raise RuntimeError(error_detail)
+
+    if errors:
+        logger.warning(
+            f"Some KBs had errors, returning {len(result)} results. Errors: {errors}"
+        )
+
+    return result
+
